@if (PageActions.Count() > 0)
{
  <Bar Breakpoint="Breakpoint.Desktop"
       Background="BackgroundColor"
       ThemeContrast="ThemeContrast.Light"
       TextColor="@TextColor"
	   Mode="BarMode.Horizontal"
		Border="Border.Is1.Rounded">
    <BarMenu>
      <BarStart>
        @{
          PopulateDictionary();

          foreach (var item in ActionGroups)
          {
            var filtered = PageActions.Where(o => o.Attribute.Group == item.Key);
            if (item.Key.ToLower() == "default" || item.Value == 1)
            {
              foreach (var action in filtered)
              {
                <BarItem TextColor="@TextColor" Border="@Borders" Margin="Margin.Is1">
                  <BarLink TextColor="@TextColor" Outline="true" @onclick="@(() => action.Method.Invoke(Context, null))">
                    <Icon Name="@action.Attribute.Icon" TextColor="@TextColor" />
                    @(action.Attribute.Caption ?? action.Method.Name)
                  </BarLink>
                </BarItem>
              }
            }
            else
            {
              <BarItem  Border="@Borders" Margin="Margin.Is1">
                <BarDropdown TextColor="@TextColor">
                  <BarDropdownToggle TextColor="@TextColor">@item.Key</BarDropdownToggle>
                  <BarDropdownMenu>
                    @foreach (var action in filtered)
                    {
                      <BarDropdownItem TextColor="@TextColor">
                        <BarLink TextColor="@TextColor" @onclick="@(() => action.Method.Invoke(Context, null))">
                          <Icon Name="@action.Attribute.Icon" TextColor="@TextColor" />
                          @(action.Attribute.Caption ?? action.Method.Name)
                        </BarLink>
                      </BarDropdownItem>
                    }
                  </BarDropdownMenu>
                </BarDropdown>
              </BarItem>
            }
          }

        }
      </BarStart>
    </BarMenu>
  </Bar>
}